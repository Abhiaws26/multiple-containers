pipeline{
    agent any
    stages{
        stage ("Build") {
            steps {
                sh "docker build -t itsverysimple/ci/cd:v1 ."

            }
        }
        stage ("Push") {
            steps {
                sh "docker push itsverysimple/ci/cd:v1"
            }
    }
    stage ("Deploy") {
        steps {
            sh "kubectl apply -f blue-dep.yaml"
        }
    }
}
}