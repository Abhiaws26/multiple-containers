pipeline {
    agent any
    stages {
        stage('Build') {
            steps {
                sh 'docker build -t itsverysimple/node-ci/cd:${BUILD_NUMBER} .'
            }
        }
        stage('Load') {
            steps {
                sh 'kind load docker-image itsverysimple/node-ci/cd:${BUILD_NUMBER}'
            }
        }
        stage('Deploy') {
            steps {
                sh 'kubectl set image deployment/node-api node-api=itsverysimple/node-ci/cd:${BUILD_NUMBER} -n prod'
            }
        }
    }
}
